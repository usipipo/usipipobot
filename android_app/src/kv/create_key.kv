#:kivy 2.0.0
#:import dp kivy.metrics.dp
#:import Clock kivy.clock.Clock

<CreateKeyScreen>:
    name: "create_key"

    # Main layout
    MDBoxLayout:
        orientation: "vertical"
        spacing: 0
        padding: 0

        # Top App Bar
        MDTopAppBarBar:
            id: top_app_bar
            title: f"Nueva Clave · Paso {root.current_step} de {root.total_steps}"
            left_action_items: [["arrow-left", lambda x: root.on_back_pressed(), "Volver", dp(24)]]
            elevation: 2
            md_bg_color: app.theme_cls.bg_dark
            specific_text_color: 0, 0.941, 1, 1  # neon_cyan

        # Content area (ScrollView)
        ScrollView:
            do_scroll_x: False
            bar_width: dp(4)

            MDBoxLayout:
                orientation: "vertical"
                padding: dp(16)
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height

                # Loading state
                MDScreen:
                    size_hint_y: None
                    height: dp(400) if root.is_loading else 0
                    opacity: 1 if root.is_loading else 0

                    MDSpinner:
                        size_hint: None, None
                        size: dp(46), dp(46)
                        pos_hint: {"center_x": 0.5, "center_y": 0.5}
                        active: True

                    MDLabel:
                        text: "Creando tu clave VPN..."
                        font_style: "Subtitle1"
                        theme_text_color: "Primary"
                        halign: "center"
                        pos_hint: {"center_x": 0.5, "center_y": 0.4}
                        size_hint_y: None
                        height: dp(40)

                # Error state
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(16)
                    padding: dp(20)
                    size_hint_y: None
                    height: self.minimum_height if root.has_error else 0
                    opacity: 0 if not root.has_error else 1

                    MDIcon:
                        icon: "alert-circle-outline"
                        font_size: dp(48)
                        theme_text_color: "Error"
                        halign: "center"
                        size_hint_y: None
                        height: dp(48)

                    MDLabel:
                        text: "Error al crear la clave"
                        font_style: "H6"
                        halign: "center"
                        theme_text_color: "Error"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    MDLabel:
                        text: root.error_message
                        font_style: "Body2"
                        halign: "center"
                        theme_text_color: "Hint"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    MDRaisedButton:
                        text: "REINTENTAR"
                        pos_hint: {"center_x": 0.5}
                        size_hint_x: None
                        width: dp(150)
                        height: dp(40)
                        on_release: root.go_to_step(1)

                # STEP 1: Protocol Selection
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(16)
                    padding: dp(8)
                    size_hint_y: None
                    height: self.minimum_height if root.current_step == 1 else 0
                    opacity: 0 if root.current_step != 1 else 1

                    MDLabel:
                        text: "¿Qué protocolo quieres usar?"
                        font_style: "H6"
                        theme_text_color: "Primary"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    MDLabel:
                        text: "Elige el protocolo según tus necesidades de privacidad y velocidad"
                        font_style: "Body2"
                        theme_text_color: "Secondary"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    # Outline Card
                    MDCard:
                        orientation: "vertical"
                        padding: dp(16)
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_height
                        md_bg_color: 0.102, 0.102, 0.141, 1 if root.selected_protocol != "outline" else 0, 0.941, 1, 0.15
                        radius: [dp(12)]
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.on_protocol_selected("outline")

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: dp(12)
                            size_hint_y: None
                            height: dp(40)

                            MDIcon:
                                icon: "shield-check"
                                font_size: dp(24)
                                theme_text_color: "Custom"
                                color: 0, 0.941, 1, 1  # neon_cyan
                                size_hint_x: None
                                width: dp(24)

                            MDLabel:
                                text: "OUTLINE (Shadowsocks)"
                                font_style: "Subtitle1"
                                font_name: "JetBrainsMono"
                                theme_text_color: "Primary"
                                size_hint_y: None
                                height: self.texture_size[1]

                            Widget:

                            MDIcon:
                                icon: "check-circle" if root.selected_protocol == "outline" else "circle-outline"
                                font_size: dp(24)
                                theme_text_color: "Custom"
                                color: 0, 0.941, 1, 1
                                size_hint_x: None
                                width: dp(24)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(8)
                            padding: dp(8, 0, 0, 0)

                            MDLabel:
                                text: "✅ Más compatible con países con censura"
                                font_style: "Body2"
                                theme_text_color: "Secondary"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                            MDLabel:
                                text: "✅ Fácil de configurar"
                                font_style: "Body2"
                                theme_text_color: "Secondary"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                            MDLabel:
                                text: "✅ Funciona en la mayoría de países con censura"
                                font_style: "Body2"
                                theme_text_color: "Secondary"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                            MDLabel:
                                text: "📱 App: Outline Client (iOS/Android)"
                                font_style: "Caption"
                                theme_text_color: "Hint"
                                size_hint_y: None
                                height: self.texture_size[1]

                        # Inline blocked message
                        MDLabel:
                            text: root.outline_blocked_reason
                            font_style: "Caption"
                            theme_text_color: "Error"
                            halign: "center"
                            size_hint_y: None
                            height: self.texture_size[1] + dp(10)
                            opacity: 1 if not root.can_create_outline else 0
                            size_hint_y: None if not root.can_create_outline else 0
                            height: self.texture_size[1] + dp(10) if not root.can_create_outline else 0

                    # WireGuard Card
                    MDCard:
                        orientation: "vertical"
                        padding: dp(16)
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_height
                        md_bg_color: 0.102, 0.102, 0.141, 1 if root.selected_protocol != "wireguard" else 1, 0, 0.667, 0.15
                        radius: [dp(12)]
                        elevation: 0
                        ripple_behavior: True
                        on_release: root.on_protocol_selected("wireguard")

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: dp(12)
                            size_hint_y: None
                            height: dp(40)

                            MDIcon:
                                icon: "speedometer"
                                font_size: dp(24)
                                theme_text_color: "Custom"
                                color: 1, 0, 0.667, 1  # neon_magenta
                                size_hint_x: None
                                width: dp(24)

                            MDLabel:
                                text: "WIREGUARD"
                                font_style: "Subtitle1"
                                font_name: "JetBrainsMono"
                                theme_text_color: "Primary"
                                size_hint_y: None
                                height: self.texture_size[1]

                            Widget:

                            MDIcon:
                                icon: "check-circle" if root.selected_protocol == "wireguard" else "circle-outline"
                                font_size: dp(24)
                                theme_text_color: "Custom"
                                color: 1, 0, 0.667, 1
                                size_hint_x: None
                                width: dp(24)

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(8)
                            padding: dp(8, 0, 0, 0)

                            MDLabel:
                                text: "✅ Más rápido y moderno"
                                font_style: "Body2"
                                theme_text_color: "Secondary"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                            MDLabel:
                                text: "✅ Mejor para gaming/video streaming"
                                font_style: "Body2"
                                theme_text_color: "Secondary"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                            MDLabel:
                                text: "⚠️ Puede ser bloqueado en algunos países"
                                font_style: "Body2"
                                theme_text_color: "Secondary"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                            MDLabel:
                                text: "📱 App: WireGuard (iOS/Android)"
                                font_style: "Caption"
                                theme_text_color: "Hint"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(10)

                        # Inline blocked message
                        MDLabel:
                            text: root.wireguard_blocked_reason
                            font_style: "Caption"
                            theme_text_color: "Error"
                            halign: "center"
                            size_hint_y: None
                            height: self.texture_size[1] + dp(10)
                            opacity: 1 if not root.can_create_wireguard else 0
                            size_hint_y: None if not root.can_create_wireguard else 0
                            height: self.texture_size[1] + dp(10) if not root.can_create_wireguard else 0

                    # Bottom spacer for navigation
                    Widget:
                        size_hint_y: None
                        height: dp(80)

                # STEP 2: Key Naming
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(16)
                    padding: dp(8)
                    size_hint_y: None
                    height: self.minimum_height if root.current_step == 2 else 0
                    opacity: 0 if root.current_step != 2 else 1

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing: dp(8)
                        size_hint_y: None
                        height: dp(30)

                        MDIcon:
                            icon: "label-outline"
                            font_size: dp(20)
                            theme_text_color: "Custom"
                            color: 0, 0.941, 1, 1
                            size_hint_x: None
                            width: dp(20)

                        MDLabel:
                            text: "Protocolo: "
                            font_style: "Body2"
                            theme_text_color: "Secondary"
                            size_hint_y: None
                            height: self.texture_size[1]

                        MDIcon:
                            icon: "check-circle"
                            font_size: dp(16)
                            theme_text_color: "Custom"
                            color: 0, 0.941, 1, 1
                            size_hint_x: None
                            width: dp(16)
                            pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: "Outline" if root.selected_protocol == "outline" else "WireGuard"
                            font_style: "Body2"
                            font_name: "JetBrainsMono"
                            theme_text_color: "Primary"
                            size_hint_y: None
                            height: self.texture_size[1]

                    MDLabel:
                        text: "Dale un nombre a esta clave para identificarla fácilmente:"
                        font_style: "H6"
                        theme_text_color: "Primary"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    # Name input field
                    MDTextField:
                        id: key_name_input
                        text: root.key_name
                        hint_text: "Ej: Mi iPhone, Mi PC de trabajo..."
                        helper_text: root.name_error_message if root.has_name_error else "Máximo 30 caracteres"
                        helper_text_mode: "on_error" if root.has_name_error else "persistent"
                        icon_left: "label"
                        max_length: 30
                        size_hint_x: 1
                        height: dp(48)
                        multiline: False
                        write_tab: False
                        on_text: root.on_name_text(self.text)

                    # Character counter
                    MDLabel:
                        text: f"{root.char_count}/{root.max_chars}"
                        font_style: "Caption"
                        font_name: "JetBrainsMono"
                        theme_text_color: "Secondary"
                        halign: "right"
                        size_hint_y: None
                        height: self.texture_size[1]

                    # Suggestion chips
                    MDLabel:
                        text: "Sugerencias:"
                        font_style: "Caption"
                        theme_text_color: "Hint"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    # Chips container (horizontal scroll)
                    ScrollView:
                        do_scroll_y: False
                        bar_width: 0
                        size_hint_y: None
                        height: dp(50)

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: dp(8)
                            padding: dp(8, 0, 0, 0)
                            size_hint_y: None
                            height: dp(40)

                            MDCard:
                                text: "Mi iPhone"
                                size_hint_x: None
                                width: dp(100)
                                radius: [dp(20)]
                                ripple_behavior: True
                                elevation: 0
                                md_bg_color: 0.102, 0.102, 0.141, 1
                                on_release: root.on_suggestion_pressed("Mi iPhone")

                                MDLabel:
                                    text: "Mi iPhone"
                                    font_style: "Caption"
                                    halign: "center"
                                    valign: "middle"

                            MDCard:
                                text: "Mi PC"
                                size_hint_x: None
                                width: dp(80)
                                radius: [dp(20)]
                                ripple_behavior: True
                                elevation: 0
                                md_bg_color: 0.102, 0.102, 0.141, 1
                                on_release: root.on_suggestion_pressed("Mi PC")

                                MDLabel:
                                    text: "Mi PC"
                                    font_style: "Caption"
                                    halign: "center"
                                    valign: "middle"

                            MDCard:
                                text: "Mi tablet"
                                size_hint_x: None
                                width: dp(100)
                                radius: [dp(20)]
                                ripple_behavior: True
                                elevation: 0
                                md_bg_color: 0.102, 0.102, 0.141, 1
                                on_release: root.on_suggestion_pressed("Mi tablet")

                                MDLabel:
                                    text: "Mi tablet"
                                    font_style: "Caption"
                                    halign: "center"
                                    valign: "middle"

                            MDCard:
                                text: "Trabajo"
                                size_hint_x: None
                                width: dp(90)
                                radius: [dp(20)]
                                ripple_behavior: True
                                elevation: 0
                                md_bg_color: 0.102, 0.102, 0.141, 1
                                on_release: root.on_suggestion_pressed("Trabajo")

                                MDLabel:
                                    text: "Trabajo"
                                    font_style: "Caption"
                                    halign: "center"
                                    valign: "middle"

                            MDCard:
                                text: "Casa"
                                size_hint_x: None
                                width: dp(70)
                                radius: [dp(20)]
                                ripple_behavior: True
                                elevation: 0
                                md_bg_color: 0.102, 0.102, 0.141, 1
                                on_release: root.on_suggestion_pressed("Casa")

                                MDLabel:
                                    text: "Casa"
                                    font_style: "Caption"
                                    halign: "center"
                                    valign: "middle"

                            MDCard:
                                text: "Viajes"
                                size_hint_x: None
                                width: dp(80)
                                radius: [dp(20)]
                                ripple_behavior: True
                                elevation: 0
                                md_bg_color: 0.102, 0.102, 0.141, 1
                                on_release: root.on_suggestion_pressed("Viajes")

                                MDLabel:
                                    text: "Viajes"
                                    font_style: "Caption"
                                    halign: "center"
                                    valign: "middle"

                    # Bottom spacer for navigation
                    Widget:
                        size_hint_y: None
                        height: dp(80)

                # STEP 3: Confirmation
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(16)
                    padding: dp(8)
                    size_hint_y: None
                    height: self.minimum_height if root.current_step == 3 else 0
                    opacity: 0 if root.current_step != 3 else 1

                    MDLabel:
                        text: "Resumen de tu nueva clave:"
                        font_style: "H6"
                        theme_text_color: "Primary"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    # Summary card
                    MDCard:
                        orientation: "vertical"
                        padding: dp(20)
                        spacing: dp(16)
                        size_hint_y: None
                        height: self.minimum_height
                        md_bg_color: 0.102, 0.102, 0.141, 1
                        radius: [dp(12)]
                        elevation: 0

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: dp(12)
                            size_hint_y: None
                            height: dp(40)

                            MDIcon:
                                icon: "check-circle"
                                font_size: dp(24)
                                theme_text_color: "Custom"
                                color: 0, 0.941, 1, 1
                                size_hint_x: None
                                width: dp(24)

                            MDLabel:
                                text: "Configuración"
                                font_style: "Subtitle1"
                                font_name: "JetBrainsMono"
                                theme_text_color: "Primary"
                                size_hint_y: None
                                height: self.texture_size[1]

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(12)
                            padding: dp(8, 0, 0, 0)

                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: dp(30)

                                MDLabel:
                                    text: "Nombre:"
                                    font_style: "Body2"
                                    theme_text_color: "Secondary"
                                    size_hint_x: 0.4
                                    size_hint_y: None
                                    height: self.texture_size[1]

                                MDLabel:
                                    text: root.key_name
                                    font_style: "Body2"
                                    font_name: "JetBrainsMono"
                                    theme_text_color: "Primary"
                                    size_hint_x: 0.6
                                    size_hint_y: None
                                    height: self.texture_size[1]

                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: dp(30)

                                MDLabel:
                                    text: "Protocolo:"
                                    font_style: "Body2"
                                    theme_text_color: "Secondary"
                                    size_hint_x: 0.4
                                    size_hint_y: None
                                    height: self.texture_size[1]

                                MDLabel:
                                    text: "Outline (Shadowsocks)" if root.selected_protocol == "outline" else "WireGuard"
                                    font_style: "Body2"
                                    font_name: "JetBrainsMono"
                                    theme_text_color: "Primary"
                                    size_hint_x: 0.6
                                    size_hint_y: None
                                    height: self.texture_size[1]

                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: dp(30)

                                MDLabel:
                                    text: "Límite:"
                                    font_style: "Body2"
                                    theme_text_color: "Secondary"
                                    size_hint_x: 0.4
                                    size_hint_y: None
                                    height: self.texture_size[1]

                                MDLabel:
                                    text: "5 GB incluidos"
                                    font_style: "Body2"
                                    font_name: "JetBrainsMono"
                                    theme_text_color: "Custom"
                                    text_color: 0, 1, 0.255, 1  # terminal_green
                                    size_hint_x: 0.6
                                    size_hint_y: None
                                    height: self.texture_size[1]

                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: dp(30)

                                MDLabel:
                                    text: "Servidor:"
                                    font_style: "Body2"
                                    theme_text_color: "Secondary"
                                    size_hint_x: 0.4
                                    size_hint_y: None
                                    height: self.texture_size[1]

                                MDLabel:
                                    text: root.confirmation_server
                                    font_style: "Body2"
                                    font_name: "JetBrainsMono"
                                    theme_text_color: "Primary"
                                    size_hint_x: 0.6
                                    size_hint_y: None
                                    height: self.texture_size[1]

                    # Info card
                    MDCard:
                        orientation: "horizontal"
                        padding: dp(16)
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(80)
                        md_bg_color: 0, 0.941, 1, 0.1  # neon_cyan with transparency
                        radius: [dp(8)]
                        elevation: 0

                        MDIcon:
                            icon: "information-outline"
                            font_size: dp(24)
                            theme_text_color: "Custom"
                            color: 0, 0.941, 1, 1
                            size_hint_x: None
                            width: dp(24)
                            pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: "ℹ️ Esta clave usará tus datos disponibles. Si no tienes paquete activo, tienes 5 GB gratuitos."
                            font_style: "Body2"
                            theme_text_color: "Secondary"
                            valign: "middle"
                            size_hint_y: None
                            height: self.texture_size[1] + dp(20)

                    # Bottom spacer for navigation
                    Widget:
                        size_hint_y: None
                        height: dp(80)

        # Bottom Navigation Bar (with Atrás/Siguiente buttons)
        MDBoxLayout:
            orientation: "horizontal"
            padding: dp(16, 8)
            spacing: dp(12)
            size_hint_y: None
            height: dp(70)
            md_bg_color: 0.071, 0.071, 0.102, 1  # bg_surface

            MDRaisedButton:
                text: "← Atrás"
                size_hint_x: 0.5
                height: dp(48)
                md_bg_color: 0.102, 0.102, 0.141, 1
                text_color: 0, 0.941, 1, 1
                line_color: 0, 0.941, 1, 1, 0.5
                radius: [dp(8)]
                on_release: root.on_back_pressed()

            MDRaisedButton:
                text: "Siguiente →" if root.current_step < 3 else "✅ Crear Clave"
                size_hint_x: 0.5
                height: dp(48)
                md_bg_color: 0, 0.941, 1, 1
                text_color: 0.039, 0.039, 0.059, 1
                radius: [dp(8)]
                on_release: root.on_next_pressed() if root.current_step < 3 else root.on_create_key_pressed()
