// Dashboard screen KV for uSipipo VPN Android APK
// Cyberpunk theme with neon colors

#:import HexColor kivy.utils.HexColor
#:import dp kivy.metrics.dp
#:import app kivy.app.App

<DashboardScreen>:
    name: "dashboard"
    md_bg_color: app.theme_cls.colors.bg_void if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_void') else HexColor("#0a0a0f")

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.colors.bg_void if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_void') else HexColor("#0a0a0f")

        # ==================== OFFLINE BANNER ====================
        # Visible when device is offline
        MDLabel:
            text: "⚠️ Sin conexión. Los datos pueden no estar actualizados."
            font_style: "Caption"
            theme_text_color: "Custom"
            text_color: [1, 1, 1, 1]  # White
            size_hint_y: None
            height: dp(30)
            md_bg_color: [1, 0.267, 0.267, 1]  # Red
            padding: [dp(10), dp(5)]
            halign: "center"
            valign: "center"
            opacity: 1 if root.is_offline else 0
            disabled: not root.is_offline

        # ==================== TOP BAR ====================
        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(56)
            padding: [dp(10), dp(8)]
            md_bg_color: app.theme_cls.colors.bg_surface if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_surface') else HexColor("#12121a")
            spacing: dp(10)

            # Menu button (hamburger)
            MDIconButton:
                icon: "menu"
                theme_text_color: "Custom"
                text_color: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                size_hint_x: None
                width: dp(40)
                pos_hint: {"center_y": 0.5}
                on_release: root.on_menu_pressed()

            # Logo/Title
            MDLabel:
                text: "uSipipo VPN"
                font_style: "Title"
                theme_text_color: "Custom"
                text_color: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                halign: "center"

            # Profile avatar button with user photo or initials
            MDCard:
                orientation: "vertical"
                size_hint_x: None
                width: dp(40)
                pos_hint: {"center_y": 0.5}
                radius: [dp(20)]  # Circle
                ripple_behavior: True
                on_release: root.on_profile_pressed()

                MDBoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(40)

                    # User photo if available
                    MDSmallestButton:
                        icon: "account-circle" if not root.user_avatar else ""
                        source: root.user_avatar if root.user_avatar else ""
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.colors.neon_magenta if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_magenta') else HexColor("#ff00aa")
                        size_hint: 1, 1
                        pos_hint: {"center_x": 0.5, "center_y": 0.5}

                    # Fallback initials (shown when no photo)
                    MDLabel:
                        text: root.username[:2].upper() if root.username and not root.user_avatar else "??"
                        font_style: "Caption"
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.colors.neon_magenta if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_magenta') else HexColor("#ff00aa")
                        halign: "center"
                        valign: "center"
                        opacity: 0 if root.user_avatar else 1
                        md_bg_color: app.theme_cls.colors.neon_magenta if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_magenta') else HexColor("#ff00aa")

        # ==================== SCROLLABLE CONTENT ====================
        MDScrollView:
            do_scroll_x: False

            MDBoxLayout:
                orientation: "vertical"
                padding: [dp(16), dp(16)]
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height

                # ==================== SKELETON LOADER ====================
                # Visible when loading data
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(16)
                    size_hint_y: None
                    height: dp(600)
                    opacity: 1 if root.is_loading else 0
                    disabled: not root.is_loading

                    # Skeleton welcome card
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(20), dp(20)]
                        spacing: dp(10)
                        size_hint_y: None
                        height: dp(140)
                        md_bg_color: [0.2, 0.2, 0.25, 1]
                        radius: [dp(12)]

                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(30)

                            Widget:
                                size_hint_x: None
                                width: dp(100)

                            MDSeparator:
                                orientation: "horizontal"
                                size_hint_x: 0.5
                                pos_hint: {"center_y": 0.5}

                            Widget:
                                size_hint_x: None
                                width: dp(50)

                        Widget:
                            size_hint_y: None
                            height: dp(20)

                        MDSeparator:
                            orientation: "horizontal"
                            size_hint_x: 0.3

                    # Skeleton data cards
                    MDGridLayout:
                        cols: 2
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(120)

                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]
                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]

                    # Skeleton 2x2 grid
                    MDGridLayout:
                        cols: 2
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(200)

                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]
                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]
                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]
                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]

                    # Skeleton quick actions
                    MDGridLayout:
                        cols: 3
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(100)

                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]
                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]
                        MDCard:
                            md_bg_color: [0.2, 0.2, 0.25, 1]
                            radius: [dp(12)]

                    # Skeleton recent keys
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(16), dp(16)]
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(180)
                        md_bg_color: [0.2, 0.2, 0.25, 1]
                        radius: [dp(12)]

                        MDSeparator:
                            orientation: "horizontal"
                            size_hint_x: 0.5

                        MDSeparator:
                            orientation: "horizontal"
                            size_hint_x: 0.5

                        MDSeparator:
                            orientation: "horizontal"
                            size_hint_x: 0.5

                # ==================== CONTENT (visible when not loading) ====================
                # Only show content when not loading
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(16)
                    size_hint_y: None
                    height: self.minimum_height
                    opacity: 0 if root.is_loading else 1
                    disabled: root.is_loading

                # ==================== SUSPENDED OVERLAY ====================
                # Visible only when user is suspended
                MDCard:
                    orientation: "vertical"
                    padding: [dp(20), dp(20)]
                    spacing: dp(15)
                    size_hint_y: None
                    height: dp(200)
                    md_bg_color: [0.2, 0.05, 0.05, 0.95]  # Dark red tint
                    radius: [dp(12)]
                    opacity: 1 if root.is_suspended else 0
                    disabled: not root.is_suspended
                    visible: root.is_suspended

                    MDIcon:
                        icon: "lock-outline"
                        theme_text_color: "Custom"
                        text_color: [1, 0.267, 0.267, 1]  # Red
                        font_size: dp(48)
                        size_hint_y: None
                        height: dp(60)
                        halign: "center"

                    MDLabel:
                        text: "Cuenta Suspendida"
                        font_style: "Headline"
                        theme_text_color: "Custom"
                        text_color: [1, 0.267, 0.267, 1]  # Red
                        halign: "center"
                        size_hint_y: None
                        height: self.texture_size[1]

                    MDLabel:
                        text: "Contacta soporte para más información."
                        font_style: "Body"
                        theme_text_color: "Secondary"
                        halign: "center"
                        size_hint_y: None
                        height: self.texture_size[1]

                    MDRaisedButton:
                        text: "IR A SOPORTE"
                        md_bg_color: [1, 0.267, 0.267, 1]
                        size_hint_x: None
                        width: dp(200)
                        pos_hint: {"center_x": 0.5}
                        on_release: root.on_support_pressed()

                # ==================== DEBT ALERT ====================
                # Visible when user has pending debt
                MDCard:
                    orientation: "horizontal"
                    padding: [dp(15), dp(15)]
                    spacing: dp(15)
                    size_hint_y: None
                    height: dp(80)
                    md_bg_color: [0.2, 0.1, 0, 0.95]  # Dark amber tint
                    radius: [dp(12)]
                    opacity: 1 if root.has_pending_debt else 0
                    disabled: not root.has_pending_debt

                    MDIcon:
                        icon: "alert-circle"
                        theme_text_color: "Custom"
                        text_color: [1, 0.584, 0, 1]  # Amber
                        font_size: dp(32)
                        size_hint_x: None
                        width: dp(40)
                        pos_hint: {"center_y": 0.5}

                    MDLabel:
                        text: "⚠️ Tienes una deuda pendiente. Tu servicio puede suspenderse."
                        font_style: "Body"
                        theme_text_color: "Custom"
                        text_color: [1, 0.584, 0, 1]  # Amber
                        size_hint_y: None
                        height: self.texture_size[1]
                        pos_hint: {"center_y": 0.5}

                # ==================== WELCOME CARD ====================
                MDCard:
                    orientation: "vertical"
                    padding: [dp(20), dp(20)]
                    spacing: dp(10)
                    size_hint_y: None
                    height: dp(140)
                    md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                    radius: [dp(12)]

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(40)

                        MDLabel:
                            text: "👋 Hola,"
                            font_style: "Headline"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                            size_hint_x: None
                            width: self.texture_size[0]

                        MDLabel:
                            text: root.full_name if root.full_name else root.username
                            font_style: "Headline"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.text_primary if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_primary') else HexColor("#e0e0e0")

                        MDLabel:
                            text: "Último acceso: " + root.last_update
                            font_style: "Caption"
                            theme_text_color: "Hint"
                            size_hint_y: None
                            height: dp(20)
                            halign: "right"

                # ==================== DATA USAGE CARD ====================
                MDCard:
                    orientation: "vertical"
                    padding: [dp(16), dp(16)]
                    spacing: dp(12)
                    size_hint_y: None
                    height: dp(140)
                    md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                    radius: [dp(12)]
                    on_release: root.on_keys_pressed()

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(30)

                        MDIcon:
                            icon: "chart-pie"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                            font_size: dp(24)
                            size_hint_x: None
                            width: dp(30)

                        MDLabel:
                            text: "DATOS"
                            font_style: "Subtitle"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.text_primary if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_primary') else HexColor("#e0e0e0")

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(40)

                        MDLabel:
                            text: root.data_used
                            font_style: "H4"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                            bold: True

                        MDLabel:
                            text: "de " + root.data_limit
                            font_style: "Body"
                            theme_text_color: "Secondary"
                            pos_hint: {"center_y": 0.5}

                    # Progress bar
                    MDBoxLayout:
                        orientation: "vertical"
                        size_hint_y: None
                        height: dp(20)
                        pos_hint: {"center_y": 0.5}

                        MDSlider:
                            id: data_progress
                            min: 0
                            max: 100
                            value: root.data_percentage
                            size_hint_y: None
                            height: dp(20)
                            theme_track_color: "Custom"
                            track_color: [0.2, 0.2, 0.25, 1]
                            theme_thumb_color: "Custom"
                            thumb_color: root.data_progress_color

                    MDLabel:
                        text: str(int(root.data_percentage)) + "% utilizado"
                        font_style: "Caption"
                        theme_text_color: "Secondary"
                        size_hint_y: None
                        height: dp(15)

                # ==================== 2x2 GRID CARDS ====================
                MDGridLayout:
                    cols: 2
                    spacing: dp(12)
                    size_hint_y: None
                    height: dp(200)

                    # Keys Card
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(16), dp(16)]
                        spacing: dp(10)
                        md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                        radius: [dp(12)]
                        on_release: root.on_keys_pressed()

                        MDIcon:
                            icon: "key-variant"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                            font_size: dp(36)
                            size_hint_y: None
                            height: dp(50)
                            halign: "center"

                        MDLabel:
                            text: "CLAVES"
                            font_style: "Subtitle"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.text_primary if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_primary') else HexColor("#e0e0e0")
                            halign: "center"
                            size_hint_y: None
                            height: dp(25)

                        MDLabel:
                            text: str(root.active_keys_count) + " activas"
                            font_style: "Body"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(20)

                        MDLabel:
                            text: "max: " + str(root.max_keys)
                            font_style: "Caption"
                            theme_text_color: "Hint"
                            halign: "center"
                            size_hint_y: None
                            height: dp(15)

                    # Referrals Card
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(16), dp(16)]
                        spacing: dp(10)
                        md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                        radius: [dp(12)]
                        on_release: root.on_profile_pressed()

                        MDIcon:
                            icon: "star"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.neon_magenta if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_magenta') else HexColor("#ff00aa")
                            font_size: dp(36)
                            size_hint_y: None
                            height: dp(50)
                            halign: "center"

                        MDLabel:
                            text: "REFERIDOS"
                            font_style: "Subtitle"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.text_primary if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_primary') else HexColor("#e0e0e0")
                            halign: "center"
                            size_hint_y: None
                            height: dp(25)

                        MDLabel:
                            text: str(root.referral_credits) + " créditos"
                            font_style: "Body"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(20)

                    # Package Card
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(16), dp(16)]
                        spacing: dp(10)
                        md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                        radius: [dp(12)]
                        on_release: root.on_buy_pressed()

                        MDIcon:
                            icon: "package-variant"
                            theme_text_color: "Custom"
                            text_color: root.package_color
                            font_size: dp(36)
                            size_hint_y: None
                            height: dp(50)
                            halign: "center"

                        MDLabel:
                            text: "PAQUETE"
                            font_style: "Subtitle"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.text_primary if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_primary') else HexColor("#e0e0e0")
                            halign: "center"
                            size_hint_y: None
                            height: dp(25)

                        MDLabel:
                            text: root.package_type
                            font_style: "Body"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(20)

                        MDLabel:
                            text: root.package_days_remaining
                            font_style: "Caption"
                            theme_text_color: "Hint"
                            halign: "center"
                            size_hint_y: None
                            height: dp(15)

                    # Consumption Mode Card (conditional)
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(16), dp(16)]
                        spacing: dp(10)
                        md_bg_color: [0.2, 0.15, 0, 1]  # Dark amber tint
                        radius: [dp(12)]
                        opacity: 1 if root.consumption_mode_enabled else 0
                        disabled: not root.consumption_mode_enabled
                        size_hint_y: None
                        height: dp(100) if root.consumption_mode_enabled else 0

                        MDIcon:
                            icon: "flash"
                            theme_text_color: "Custom"
                            text_color: [1, 0.584, 0, 1]  # Amber
                            font_size: dp(36)
                            size_hint_y: None
                            height: dp(50)
                            halign: "center"

                        MDLabel:
                            text: "CONSUMO"
                            font_style: "Subtitle"
                            theme_text_color: "Custom"
                            text_color: [1, 0.584, 0, 1]
                            halign: "center"
                            size_hint_y: None
                            height: dp(25)

                        MDLabel:
                            text: "Pay-as-you-go"
                            font_style: "Caption"
                            theme_text_color: "Custom"
                            text_color: [1, 0.584, 0, 1]
                            halign: "center"
                            size_hint_y: None
                            height: dp(20)

                # ==================== QUICK ACTIONS ====================
                MDLabel:
                    text: "─── Acciones Rápidas ───"
                    font_style: "Subtitle"
                    theme_text_color: "Custom"
                    text_color: app.theme_cls.colors.text_secondary if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_secondary') else HexColor("#8a8a9a")
                    halign: "center"
                    size_hint_y: None
                    height: dp(30)

                MDGridLayout:
                    cols: 3
                    spacing: dp(12)
                    size_hint_y: None
                    height: dp(100)

                    # New Key Button
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(12), dp(12)]
                        spacing: dp(8)
                        md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                        radius: [dp(12)]
                        on_release: root.on_new_key_pressed()

                        MDIcon:
                            icon: "key-plus"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                            font_size: dp(32)
                            size_hint_y: None
                            height: dp(45)
                            halign: "center"

                        MDLabel:
                            text: "Nueva"
                            font_style: "Caption"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(15)

                        MDLabel:
                            text: "Clave"
                            font_style: "Caption"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(15)

                    # Buy GB Button
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(12), dp(12)]
                        spacing: dp(8)
                        md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                        radius: [dp(12)]
                        on_release: root.on_buy_gb_pressed()

                        MDIcon:
                            icon: "database-plus"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.terminal_green if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'terminal_green') else HexColor("#00ff41")
                            font_size: dp(32)
                            size_hint_y: None
                            height: dp(45)
                            halign: "center"

                        MDLabel:
                            text: "Comprar"
                            font_style: "Caption"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(15)

                        MDLabel:
                            text: "GB"
                            font_style: "Caption"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(15)

                    # Support Button
                    MDCard:
                        orientation: "vertical"
                        padding: [dp(12), dp(12)]
                        spacing: dp(8)
                        md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                        radius: [dp(12)]
                        on_release: root.on_support_pressed()

                        MDIcon:
                            icon: "headset"
                            theme_text_color: "Custom"
                            text_color: app.theme_cls.colors.neon_magenta if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_magenta') else HexColor("#ff00aa")
                            font_size: dp(32)
                            size_hint_y: None
                            height: dp(45)
                            halign: "center"

                        MDLabel:
                            text: "Soporte"
                            font_style: "Caption"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(15)

                        MDLabel:
                            text: ""
                            font_style: "Caption"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: dp(15)

                # ==================== RECENT KEYS ====================
                MDLabel:
                    text: "─── Últimas Claves ───"
                    font_style: "Subtitle"
                    theme_text_color: "Custom"
                    text_color: app.theme_cls.colors.text_secondary if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_secondary') else HexColor("#8a8a9a")
                    halign: "center"
                    size_hint_y: None
                    height: dp(30)

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(10)
                    size_hint_y: None
                    height: self.minimum_height

                    # Dynamic key cards based on recent_keys list
                    # This is a placeholder - actual implementation would use RecycleView
                    # For now, showing static example cards

                    MDCard:
                        orientation: "horizontal"
                        padding: [dp(15), dp(15)]
                        spacing: dp(15)
                        size_hint_y: None
                        height: dp(80)
                        md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                        radius: [dp(12)]

                        MDIcon:
                            icon: "check-circle"
                            theme_text_color: "Custom"
                            text_color: [0, 0.941, 1, 1]  # neon_cyan
                            font_size: dp(28)
                            size_hint_x: None
                            width: dp(35)
                            pos_hint: {"center_y": 0.5}

                        MDBoxLayout:
                            orientation: "vertical"
                            pos_hint: {"center_y": 0.5}

                            MDLabel:
                                text: "Mi iPhone · Outline"
                                font_style: "Body"
                                theme_text_color: "Primary"
                                size_hint_y: None
                                height: dp(25)

                            MDLabel:
                                text: "1.2 GB usados · Activa"
                                font_style: "Caption"
                                theme_text_color: "Secondary"
                                size_hint_y: None
                                height: dp(18)

                        MDIconButton:
                            icon: "chevron-right"
                            theme_text_color: "Secondary"
                            size_hint_x: None
                            width: dp(30)
                            pos_hint: {"center_y": 0.5}

                    MDCard:
                        orientation: "horizontal"
                        padding: [dp(15), dp(15)]
                        spacing: dp(15)
                        size_hint_y: None
                        height: dp(80)
                        md_bg_color: app.theme_cls.colors.bg_card if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_card') else HexColor("#1a1a24")
                        radius: [dp(12)]

                        MDIcon:
                            icon: "check-circle"
                            theme_text_color: "Custom"
                            text_color: [0.6, 0, 1, 1]  # purple for WireGuard
                            font_size: dp(28)
                            size_hint_x: None
                            width: dp(35)
                            pos_hint: {"center_y": 0.5}

                        MDBoxLayout:
                            orientation: "vertical"
                            pos_hint: {"center_y": 0.5}

                            MDLabel:
                                text: "Mi PC · WireGuard"
                                font_style: "Body"
                                theme_text_color: "Primary"
                                size_hint_y: None
                                height: dp(25)

                            MDLabel:
                                text: "450 MB usados · Activa"
                                font_style: "Caption"
                                theme_text_color: "Secondary"
                                size_hint_y: None
                                height: dp(18)

                        MDIconButton:
                            icon: "chevron-right"
                            theme_text_color: "Secondary"
                            size_hint_x: None
                            width: dp(30)
                            pos_hint: {"center_y": 0.5}

                    # Ver todas link
                    MDLabel:
                        text: "Ver todas →"
                        font_style: "Caption"
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                        halign: "right"
                        size_hint_y: None
                        height: dp(25)

                # Spacer for bottom nav
                MDLabel:
                    size_hint_y: None
                    height: dp(20)

        # ==================== BOTTOM NAVIGATION ====================
        MDBottomNavigation:
            size_hint_y: None
            height: dp(80)
            md_bg_color: app.theme_cls.colors.bg_surface if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'bg_surface') else HexColor("#12121a")

            MDBottomNavigationItem:
                name: "tab_home"
                text: "Inicio"
                icon: "home"
                theme_text_color: "Custom"
                text_color_active: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                text_color_inactive: app.theme_cls.colors.text_muted if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_muted') else HexColor("#5a5a6a")

            MDBottomNavigationItem:
                name: "tab_keys"
                text: "Claves"
                icon: "key"
                theme_text_color: "Custom"
                text_color_active: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                text_color_inactive: app.theme_cls.colors.text_muted if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_muted') else HexColor("#5a5a6a")
                on_release: root.on_keys_pressed()

            MDBottomNavigationItem:
                name: "tab_buy"
                text: "Comprar"
                icon: "shopping"
                theme_text_color: "Custom"
                text_color_active: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                text_color_inactive: app.theme_cls.colors.text_muted if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_muted') else HexColor("#5a5a6a")
                on_release: root.on_buy_pressed()

            MDBottomNavigationItem:
                name: "tab_profile"
                text: "Perfil"
                icon: "account"
                theme_text_color: "Custom"
                text_color_active: app.theme_cls.colors.neon_cyan if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'neon_cyan') else HexColor("#00f0ff")
                text_color_inactive: app.theme_cls.colors.text_muted if hasattr(app.theme_cls, 'colors') and hasattr(app.theme_cls.colors, 'text_muted') else HexColor("#5a5a6a")
                on_release: root.on_profile_pressed()
