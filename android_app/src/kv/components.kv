// Custom components for uSipipo VPN Android APK
// Cyberpunk-styled reusable widgets

#:import NeonButton src.components.neon_button.NeonButton
#:import OtpInput src.components.otp_input.OtpInput
#:import DataProgressBar src.components.data_progress_bar.DataProgressBar
#:import StatusBadge src.components.status_badge.StatusBadge
#:import QuickActionButton src.components.quick_action_button.QuickActionButton
#:import SkeletonLoader src.components.skeleton_loader.SkeletonLoader
#:import VpnKeyCard src.components.vpn_key_card.VpnKeyCard
#:import QrDisplay src.components.qr_display.QrDisplay

<NeonButton>:
    height: dp(48)
    size_hint_x: 1
    radius: [dp(8)]
    font_name: "Roboto"
    text: root.text

    canvas.before:
        Color:
            rgba: root.neon_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
            width: 2

    canvas.after:
        # Glow effect (simulated with larger rectangle)
        Color:
            rgba: [*root.neon_color[:3], 0.3]
        RoundedRectangle:
            pos: self.x - dp(2), self.y - dp(2)
            size: self.width + dp(4), self.height + dp(4)
            radius: [dp(10)]

<OtpInput>:
    orientation: "horizontal"
    spacing: dp(10)
    padding: dp(10)
    size_hint_y: None
    height: dp(60)

<DataProgressBar>:
    orientation: "vertical"
    size_hint_y: None
    height: dp(30)
    padding: dp(5)
    spacing: dp(5)

    MDBoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: dp(20)

        MDLabel:
            text: root.label_text
            font_style: "Caption"
            theme_text_color: "Secondary"
            size_hint_x: None
            width: self.texture_size[0]

        MDLabel:
            text: root.value_text
            font_style: "Caption"
            theme_text_color: "Secondary"
            halign: "right"

    MDSlider:
        id: slider
        min: 0
        max: 100
        value: root.percentage
        size_hint_y: None
        height: dp(20)
        theme_track_color: "Custom"
        track_color: [0.2, 0.2, 0.25, 1]
        theme_thumb_color: "Custom"
        thumb_color: root.bar_color

<StatusBadge>:
    orientation: "horizontal"
    size_hint_x: None
    width: self.minimum_width
    padding: [dp(8), dp(4)]
    spacing: dp(6)
    radius: [dp(12)]

    MDIcon:
        icon: root.status_icon
        theme_text_color: "Custom"
        text_color: root.status_color
        font_size: dp(14)
        size_hint_x: None
        width: dp(16)

    MDLabel:
        text: root.status_text
        font_style: "Caption"
        theme_text_color: "Custom"
        text_color: root.status_color
        size_hint_x: None
        width: self.texture_size[0]

<QuickActionButton>:
    orientation: "vertical"
    padding: [dp(12), dp(12)]
    spacing: dp(8)
    size_hint: None, None
    size: [dp(90), dp(100)]
    radius: [dp(12)]
    ripple_behavior: True

    MDIcon:
        icon: root.button_icon
        theme_text_color: "Custom"
        text_color: root.icon_color
        font_size: dp(36)
        size_hint_y: None
        height: dp(50)
        pos_hint: {"center_x": 0.5}

    MDLabel:
        text: root.button_text
        font_style: "Caption"
        theme_text_color: "Secondary"
        halign: "center"
        size_hint_y: None
        height: dp(20)

<SkeletonLoader>:
    orientation: "vertical"
    size_hint_y: None
    md_bg_color: [0.15, 0.15, 0.2, 1]
    radius: [dp(8)]

    Widget:
        size_hint_y: None
        height: dp(20)

<VpnKeyCard>:
    orientation: "horizontal"
    padding: [dp(15), dp(15)]
    spacing: dp(15)
    size_hint_y: None
    height: dp(80)
    radius: [dp(12)]
    ripple_behavior: True

    MDIcon:
        icon: root.key_type_icon
        theme_text_color: "Custom"
        text_color: root.key_type_color
        font_size: dp(28)
        size_hint_x: None
        width: dp(35)
        pos_hint: {"center_y": 0.5}

    MDBoxLayout:
        orientation: "vertical"
        pos_hint: {"center_y": 0.5}

        MDLabel:
            text: root.key_name
            font_style: "Body"
            theme_text_color: "Primary"
            size_hint_y: None
            height: dp(25)

        MDLabel:
            text: root.key_usage
            font_style: "Caption"
            theme_text_color: "Secondary"
            size_hint_y: None
            height: dp(18)

    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: None
        width: dp(80)
        pos_hint: {"center_y": 0.5}

        MDLabel:
            text: root.key_status
            font_style: "Caption"
            theme_text_color: "Custom"
            text_color: root.status_color
            halign: "right"
            size_hint_y: None
            height: dp(20)

        MDIconButton:
            icon: "chevron-right"
            theme_text_color: "Secondary"
            size_hint_x: None
            width: dp(30)

<QrDisplay>:
    size_hint: None, None
    size: dp(200), dp(200)
    allow_stretch: True
    keep_ratio: True
