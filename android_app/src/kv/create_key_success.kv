#:kivy 2.0.0
#:import dp kivy.metrics.dp
#:import Clock kivy.clock.Clock

<CreateKeySuccessScreen>:
    name: "create_key_success"

    # Main layout
    MDBoxLayout:
        orientation: "vertical"
        spacing: 0
        padding: 0

        # Top App Bar (minimal, no back button to encourage copying)
        MDTopAppBarBar:
            id: top_app_bar
            title: "¡Clave Creada!"
            elevation: 2
            md_bg_color: app.theme_cls.bg_dark
            specific_text_color: 0, 0.941, 1, 1  # neon_cyan

        # Content area (ScrollView)
        ScrollView:
            do_scroll_x: False
            bar_width: dp(4)

            MDBoxLayout:
                orientation: "vertical"
                padding: dp(24, 32)
                spacing: dp(24)
                size_hint_y: None
                height: self.minimum_height

                # Loading state
                MDScreen:
                    size_hint_y: None
                    height: dp(400) if root.is_loading else 0
                    opacity: 1 if root.is_loading else 0

                    MDSpinner:
                        size_hint: None, None
                        size: dp(46), dp(46)
                        pos_hint: {"center_x": 0.5, "center_y": 0.5}
                        active: True

                # Error state
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(16)
                    padding: dp(20)
                    size_hint_y: None
                    height: self.minimum_height if root.has_error else 0
                    opacity: 0 if not root.has_error else 1

                    MDIcon:
                        icon: "alert-circle-outline"
                        font_size: dp(48)
                        theme_text_color: "Error"
                        halign: "center"
                        size_hint_y: None
                        height: dp(48)

                    MDLabel:
                        text: "Error al cargar la clave"
                        font_style: "H6"
                        halign: "center"
                        theme_text_color: "Error"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    MDLabel:
                        text: root.error_message
                        font_style: "Body2"
                        halign: "center"
                        theme_text_color: "Hint"
                        size_hint_y: None
                        height: self.texture_size[1] + dp(10)

                    MDRaisedButton:
                        text: "VOLVER A INTENTAR"
                        pos_hint: {"center_x": 0.5}
                        size_hint_x: None
                        width: dp(180)
                        height: dp(40)
                        on_release: root._load_key_data()

                # Success content
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(24)
                    size_hint_y: None
                    height: self.minimum_height if not root.is_loading and not root.has_error else 0
                    opacity: 0 if root.is_loading or root.has_error else 1

                    # Success icon with animation
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(8)
                        size_hint_y: None
                        height: dp(100)
                        pos_hint: {"center_x": 0.5}

                        MDIcon:
                            icon: "check-circle"
                            font_size: dp(64)
                            theme_text_color: "Custom"
                            color: 0, 1, 0.255, 1  # terminal_green
                            halign: "center"
                            size_hint_y: None
                            height: dp(64)

                        MDLabel:
                            text: "¡Clave creada exitosamente!"
                            font_style: "H5"
                            font_name: "JetBrainsMono"
                            halign: "center"
                            theme_text_color: "Primary"
                            size_hint_y: None
                            height: self.texture_size[1] + dp(10)

                    # Key name and type
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(8)
                        size_hint_y: None
                        height: self.minimum_height
                        pos_hint: {"center_x": 0.5}

                        MDLabel:
                            text: root.key_name
                            font_style: "H4"
                            font_name: "JetBrainsMono"
                            halign: "center"
                            theme_text_color: "Primary"
                            size_hint_y: None
                            height: self.texture_size[1] + dp(10)

                        MDLabel:
                            text: root.key_type_display
                            font_style: "Subtitle1"
                            theme_text_color: "Secondary"
                            halign: "center"
                            size_hint_y: None
                            height: self.texture_size[1]

                    # QR Code card with neon glow effect
                    MDCard:
                        orientation: "vertical"
                        padding: dp(24)
                        spacing: dp(20)
                        size_hint: None, None
                        size: dp(280), dp(340)
                        pos_hint: {"center_x": 0.5}
                        md_bg_color: 0.102, 0.102, 0.141, 1  # bg_card
                        radius: [dp(16)]
                        elevation: 0

                        # Neon border effect (canvas)
                        canvas.before:
                            Color:
                                rgba: 0, 0.941, 1, 0.3  # neon_cyan with 30% opacity
                            Line:
                                width: 2
                                rounded_rectangle: self.x, self.y, self.width, self.height, 16

                        MDLabel:
                            text: "📱 Escanea para conectar"
                            font_style: "Subtitle2"
                            font_name: "JetBrainsMono"
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: 0, 0.941, 1, 1
                            size_hint_y: None
                            height: dp(30)

                        # QR Code display
                        QrDisplay:
                            id: qr_display
                            qr_data: root.qr_data
                            size_hint: None, None
                            size: dp(200), dp(200)
                            pos_hint: {"center_x": 0.5}
                            allow_stretch: True
                            keep_ratio: True

                        # Connection string (truncated)
                        MDTextField:
                            id: connection_string
                            text: root.truncated_code
                            hint_text: "Código de conexión"
                            read_only: True
                            mode: "rectangle"
                            size_hint_x: 1
                            height: dp(48)
                            font_name: "JetBrainsMono"
                            font_size: dp(12)

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: dp(8)
                            size_hint_y: None
                            height: dp(40)

                            MDRaisedButton:
                                text: "📋 Copiar"
                                size_hint_x: 0.5
                                height: dp(40)
                                md_bg_color: 0, 0.941, 1, 1
                                text_color: 0.039, 0.039, 0.059, 1
                                radius: [dp(8)]
                                on_release: root.on_copy_code_pressed()

                            MDRaisedButton:
                                text: "📤 Compartir"
                                size_hint_x: 0.5
                                height: dp(40)
                                md_bg_color: 0.102, 0.102, 0.141, 1
                                text_color: 0, 0.941, 1, 1
                                line_color: 0, 0.941, 1, 1, 0.5
                                radius: [dp(8)]
                                on_release: root.on_share_pressed()

                    # Connection instructions card
                    MDCard:
                        orientation: "vertical"
                        padding: dp(16)
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_height
                        md_bg_color: 0.102, 0.102, 0.141, 1
                        radius: [dp(12)]
                        elevation: 0

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: dp(8)
                            size_hint_y: None
                            height: dp(30)

                            MDIcon:
                                icon: "download-outline"
                                font_size: dp(20)
                                theme_text_color: "Custom"
                                color: 0, 0.941, 1, 1
                                size_hint_x: None
                                width: dp(20)

                            MDLabel:
                                text: "CÓMO CONECTARSE"
                                font_style: "Subtitle2"
                                font_name: "JetBrainsMono"
                                theme_text_color: "Custom"
                                text_color: 0, 0.941, 1, 1
                                size_hint_y: None
                                height: self.texture_size[1]

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(8)
                            padding: dp(8, 0, 0, 0)

                            MDLabel:
                                text: "1. Descarga Outline Client en tu iPhone"
                                font_style: "Body2"
                                theme_text_color: "Primary"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                            MDLabel:
                                text: "2. Toca el QR o pega el código"
                                font_style: "Body2"
                                theme_text_color: "Primary"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                            MDLabel:
                                text: "3. ¡Listo! Ya tienes VPN"
                                font_style: "Body2"
                                theme_text_color: "Success"
                                size_hint_y: None
                                height: self.texture_size[1] + dp(5)

                    # Navigation buttons
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(100)
                        padding: dp(0, 16)

                        MDRaisedButton:
                            text: "Ver mis claves"
                            size_hint_x: 1
                            height: dp(48)
                            md_bg_color: 0.102, 0.102, 0.141, 1
                            text_color: 0, 0.941, 1, 1
                            line_color: 0, 0.941, 1, 1, 0.5
                            radius: [dp(8)]
                            on_release: root._navigate_to_keys_list()

                        MDRaisedButton:
                            text: "Ir al inicio"
                            size_hint_x: 1
                            height: dp(48)
                            md_bg_color: 0, 0.941, 1, 1
                            text_color: 0.039, 0.039, 0.059, 1
                            radius: [dp(8)]
                            on_release: root.on_go_home_pressed()
